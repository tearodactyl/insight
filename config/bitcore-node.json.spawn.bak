{
  "network": "livenet",
  "port": 3001,
  "services": [
    "bitcoind",
    "insight-api-zero",
    "insight-ui-zero",
    "web"
  ],
  "servicesConfig": {
    "bitcoind": {
      "spawn": {
        "datadir": "/home/ubuntu/.zero",
        "exec": "/home/ubuntu/zero/BIN/zerod"
      },
      "startRetryCount": 60
    }
  }
}
